# ============================================================
#  scorpion-ai-hub (OmniScorp) — environment variables
#  Copy to .env for local dev, or set these in Railway → Variables.
#  NEVER commit real secrets. Values below are placeholders.
# ============================================================

# --- Database (REQUIRED) ---
# Railway's MySQL plugin provides this connection string automatically.
DATABASE_URL="mysql://user:password@host:3306/railway"

# --- Session security (REQUIRED) ---
# Secret used to sign JWT session cookies (jose / HS256).
# Generate a strong value, e.g.:  openssl rand -base64 48
JWT_SECRET=""

# --- Server runtime ---
# Railway sets PORT automatically; 3000 is the local default.
PORT=3000
NODE_ENV=production

# ============================================================
#  Manus-backed services — currently REQUIRED for login + file storage
#  The app calls Manus's auth server (login) and Manus's "forge" backend
#  (file storage). Copy these values from your existing Manus deployment's
#  environment. Hosting/compute moves off Manus, but auth + storage still
#  ride these services until they're replaced (see note at bottom).
# ============================================================
VITE_APP_ID=""              # Manus app / OAuth client ID
OAUTH_SERVER_URL=""         # Manus OAuth server base URL (used for login)
OWNER_OPEN_ID=""            # Your Manus owner openId (owner notifications)
BUILT_IN_FORGE_API_URL=""   # Manus "forge" storage API base URL
BUILT_IN_FORGE_API_KEY=""   # Manus "forge" storage API key

# ------------------------------------------------------------
# TO GO FULLY OFF MANUS (phase 2): replace the auth (OAUTH_SERVER_URL +
# VITE_APP_ID, in server/_core/sdk.ts) with your own OAuth/auth, and swap
# the storage proxy (BUILT_IN_FORGE_*) for direct S3 — the
# @aws-sdk/client-s3 dependency is already in package.json.
# ------------------------------------------------------------
